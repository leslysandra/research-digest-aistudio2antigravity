    replacement_chunks {
      replacement_content: "rules_version = \'2\';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Global safety net: default-deny catch-all\n    match /{document=**} {\n      allow read, write: if false;\n    }\n\n    // Public digests collection\n    match /digests/{digestId} {\n      // Publicly readable so visitors can view synthesized archives\n      allow read, list: if true;\n      \n      // Allow creation of structured digests with strict validation\n      allow create: if isValidDigest(request.resource.data);\n      \n      // Prevent modifications or deletions to secure historical integrity\n      allow update, delete: if false;\n    }\n\n    // Validation helper to verify content structures without Auth requirements\n    function isValidDigest(data) {\n      return data.topic is string \n        && data.topic.size() > 0 \n        && data.topic.size() <= 256\n        && data.timestamp is int\n        && data.researcherFindings is list\n        && data.researcherFindings.size() <= 15\n        && data.editorDigest is map\n        && data.editorDigest.keys().hasAll([\'intro\', \'bullets\', \'takeaway\'])\n        && data.editorDigest.keys().size() == 3\n        && data.editorDigest.intro is string\n        && data.editorDigest.intro.size() <= 2000\n        && data.editorDigest.bullets is list\n        && data.editorDigest.bullets.size() <= 15\n        && data.editorDigest.takeaway is string\n        && data.editorDigest.takeaway.size() <= 2000;\n    }\n  }\n}\n"
