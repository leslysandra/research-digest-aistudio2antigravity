      replacement_content: "import { useEffect, useRef } from \"react\";\n\ninterface TerminalLogProps {\n  logs: string[];\n}\n\nexport default function TerminalLog({ logs }: TerminalLogProps) {\n  const terminalEndRef = useRef<HTMLDivElement>(null);\n\n  useEffect(() => {\n    terminalEndRef.current?.scrollIntoView({ behavior: \"smooth\" });\n  }, [logs]);\n\n  return (\n    <div className=\"bg-black/90 p-4 rounded border border-neon-magenta/55 font-mono text-[11px] leading-relaxed text-neon-magenta h-36 overflow-y-auto shadow-[0_0_15px_rgba(255,0,127,0.15)] relative bg-noise\">\n      <div className=\"absolute top-2 right-3 text-[9px] px-1 bg-neon-magenta/20 text-neon-magenta animate-pulse border border-neon-magenta/30\">\n        SYS_LOG ACTIVE\n      </div>\n      <div className=\"mb-2 text-neon-cyan/90 border-b border-neon-magenta/20 pb-1 text-xs font-bold uppercase tracking-wider\">\n        // NEURAL LINK DIAGNOSTICS TELEMETRY\n      </div>\n      <div className=\"space-y-1\">\n        {logs.map((log, index) => {\n          const isError = log.includes(\"ERROR\") || log.includes(\"FAILURE\") || log.includes(\"MISSING\");\n          const isSuccess = log.includes(\"SUCCESS\") || log.includes(\"COMPLETED\") || log.includes(\"READY\");\n          return (\n            <div\n              key={index}\n              className={`${\n                isError\n                  ? \"text-red-500 font-bold animate-pulse\"\n                  : isSuccess\n                  ? \"text-neon-cyan font-semibold\"\n                  : \"text-neon-magenta/95\"\n              }`}\n            >\n              <span className=\"text-neon-cyan mr-1.5\">&gt;</span>\n              {log}\n            </div>\n          );\n        })}\n        {logs.length === 0 && (\n          <div className=\"text-neon-magenta/40 italic\">\n            [SYSTEM IDLE. STANDING BY FOR TOPIC INPUT QUANTIZATION...]\n          </div>\n        )}\n        <div ref={terminalEndRef} />\n      </div>\n    </div>\n  );\n}\n"
