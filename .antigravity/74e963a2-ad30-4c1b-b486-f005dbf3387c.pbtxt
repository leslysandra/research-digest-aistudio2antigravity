      original_chunk {
        target_content: "@import \"tailwindcss\";"
        replacement_content: "@import url(\'https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=VT323&family=JetBrains+Mono:wght@400;700&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-mono: \"Share Tech Mono\", \"VT323\", \"JetBrains Mono\", monospace;\n  --font-sans: \"Share Tech Mono\", \"VT323\", \"JetBrains Mono\", monospace;\n  \n  --color-neon-cyan: #00f0ff;\n  --color-neon-magenta: #ff007f;\n  --color-dark-bg: #050505;\n  --color-dark-card: #0c0c0e;\n}\n\n/* CRT Screen Scanline & Noise Overlays */\n.crt-container {\n  position: relative;\n  background-color: #050505;\n  overflow: hidden;\n}\n\n.crt-container::before {\n  content: \" \";\n  display: block;\n  position: absolute;\n  top: 0; left: 0; bottom: 0; right: 0;\n  background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));\n  z-index: 10;\n  background-size: 100% 4px, 6px 100%;\n  pointer-events: none;\n}\n\n.scanline {\n  width: 100%;\n  height: 100px;\n  background: linear-gradient(\n    0deg,\n    rgba(0, 240, 255, 0) 0%,\n    rgba(0, 240, 255, 0.05) 10%,\n    rgba(0, 240, 255, 0.1) 50%,\n    rgba(0, 240, 255, 0.05) 90%,\n    rgba(0, 240, 255, 0) 100%\n  );\n  opacity: 0.8;\n  position: absolute;\n  bottom: 100%;\n  left: 0;\n  z-index: 9;\n  pointer-events: none;\n  animation: scanline-move 6s linear infinite;\n}\n\n@keyframes scanline-move {\n  0% {\n    bottom: 100%;\n  }\n  100% {\n    bottom: -100px;\n  }\n}\n\n/* Glitch & Screen Tearing Keyframes */\n@keyframes glitch-skew {\n  0%, 100% { transform: none; }\n  10% { transform: skewX(-3deg) scaleY(0.95); }\n  15% { transform: skewX(2deg) skewY(1deg); }\n  45% { transform: skewX(-1deg); }\n  50% { transform: skewX(1deg) scaleY(1.05); }\n  85% { transform: none; filter: hue-rotate(90deg); }\n}\n\n.animate-glitch {\n  animation: glitch-skew 4s infinite linear alternate-reverse;\n}\n\n@keyframes text-flicker {\n  0%, 19.999%, 22%, 62.999%, 64%, 64.999%, 70%, 100% {\n    opacity: 0.99;\n    filter: drop-shadow(0 0 1px rgba(0, 240, 255, 0.5));\n  }\n  20%, 21.999%, 63%, 63.999%, 65%, 69.999% {\n    opacity: 0.4;\n    filter: none;\n  }\n}\n\n.animate-flicker {\n  animation: text-flicker 3s infinite;\n}\n\n/* Custom Cyber Borders and Accents */\n.cyber-border-cyan {\n  border: 1px solid #00f0ff;\n  box-shadow: 0 0 8px rgba(0, 240, 255, 0.2);\n}\n\n.cyber-border-magenta {\n  border: 1px solid #ff007f;\n  box-shadow: 0 0 8px rgba(255, 0, 127, 0.2);\n}\n\n.cyber-button-magenta {\n  background: transparent;\n  color: #ff007f;\n  border: 1px solid #ff007f;\n  font-family: \"Share Tech Mono\", monospace;\n  position: relative;\n  overflow: hidden;\n  transition: all 0.1s ease;\n  cursor: pointer;\n}\n\n.cyber-button-magenta:hover {\n  background: #ff007f;\n  color: #050505;\n  box-shadow: 0 0 15px rgba(255, 0, 127, 0.6);\n  text-shadow: none;\n}\n\n.cyber-button-cyan {\n  background: transparent;\n  color: #00f0ff;\n  border: 1px solid #00f0ff;\n  font-family: \"Share Tech Mono\", monospace;\n  position: relative;\n  overflow: hidden;\n  transition: all 0.1s ease;\n  cursor: pointer;\n}\n\n.cyber-button-cyan:hover {\n  background: #00f0ff;\n  color: #050505;\n  box-shadow: 0 0 15px rgba(0, 240, 255, 0.6);\n  text-shadow: none;\n}\n\n/* Static Noise Effect */\n.bg-noise {\n  background-image: url(\"data:image/svg+xml,%3Csvg viewBox=\'0 0 200 200\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'noise\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.65\' numOctaves=\'3\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23noise)\' opacity=\'0.03\'/%3E%3C/svg%3E\");\n}\n"
