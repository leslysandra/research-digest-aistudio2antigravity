    replacement_chunks {
      replacement_content: "import { useState } from \"react\";\nimport { SavedDigest } from \"../firebase\";\nimport { Shield, Cpu, RefreshCw, Layers, ExternalLink, Sparkles } from \"lucide-react\";\nimport { motion } from \"motion/react\";\n\ninterface DigestViewerProps {\n  digest: SavedDigest;\n}\n\nexport default function DigestViewer({ digest }: DigestViewerProps) {\n  const [showRawResearcher, setShowRawResearcher] = useState(false);\n\n  const formattedDate = new Date(digest.timestamp).toLocaleString();\n\n  return (\n    <motion.div\n      initial={{ opacity: 0, y: 15 }}\n      animate={{ opacity: 1, y: 0 }}\n      exit={{ opacity: 0, y: -15 }}\n      className=\"space-y-6\"\n    >\n      {/* Active Digest Header */}\n      <div className=\"border border-neon-cyan p-4 rounded bg-dark-card/90 relative bg-noise shadow-[0_0_15px_rgba(0,240,255,0.1)]\">\n        <div className=\"absolute top-3 right-4 font-mono text-[10px] text-neon-cyan/60\">\n          STAMP: {formattedDate}\n        </div>\n        <div className=\"flex items-center gap-2 mb-1.5\">\n          <Shield className=\"w-4 height-4 text-neon-cyan animate-pulse\" />\n          <span className=\"font-mono text-xs uppercase tracking-widest text-neon-cyan/70\">\n            SECURE INTEL BRIEFING\n          </span>\n        </div>\n        <h2 className=\"font-mono text-lg md:text-2xl font-extrabold text-neon-cyan uppercase tracking-wide animate-glitch\">\n          {digest.topic}\n        </h2>\n      </div>\n\n      {/* Agent 2: Editor Output */}\n      <div className=\"border border-neon-cyan/40 p-6 rounded bg-black/80 relative overflow-hidden bg-noise shadow-md\">\n        {/* Glow corner elements */}\n        <div className=\"absolute top-0 left-0 w-2 h-2 bg-neon-cyan\"></div>\n        <div className=\"absolute top-0 right-0 w-2 h-2 bg-neon-cyan\"></div>\n        <div className=\"absolute bottom-0 left-0 w-2 h-2 bg-neon-cyan\"></div>\n        <div className=\"absolute bottom-0 right-0 w-2 h-2 bg-neon-cyan\"></div>\n\n        <div className=\"flex items-center justify-between border-b border-neon-cyan/20 pb-3 mb-4\">\n          <div className=\"flex items-center gap-2\">\n            <Cpu className=\"w-5 h-5 text-neon-cyan animate-spin\" style={{ animationDuration: \'6s\' }} />\n            <span className=\"font-mono text-sm font-bold tracking-widest text-neon-cyan uppercase\">\n              AGENT_2: SYNTAX EDITOR REPORT\n            </span>\n          </div>\n          <span className=\"text-[10px] bg-neon-cyan/10 text-neon-cyan px-2 py-0.5 border border-neon-cyan/30 uppercase font-mono\">\n            SYNTHESIS ACTIVE\n          </span>\n        </div>\n\n        {/* Intro */}\n        <p className=\"font-mono text-sm leading-relaxed text-gray-200 mb-6 border-l-2 border-neon-cyan pl-4 py-1 italic\">\n          {digest.editorDigest.intro || \"Synthesizing input streams...\"}\n        </p>\n\n        {/* Key Points list */}\n        <div className=\"space-y-4 mb-6\">\n          <div className=\"font-mono text-xs text-neon-cyan/60 uppercase tracking-widest mb-1\">\n            // CONDENSED COGNITIVE POINTS:\n          </div>\n          {digest.editorDigest.bullets.map((bullet, idx) => (\n            <motion.div\n              initial={{ opacity: 0, x: -10 }}\n              animate={{ opacity: 1, x: 0 }}\n              transition={{ delay: idx * 0.1 }}\n              key={idx}\n              className=\"flex items-start gap-3 bg-neon-cyan/5 p-3 rounded border border-neon-cyan/15 hover:border-neon-cyan/40 transition-colors\"\n            >\n              <div className=\"mt-1 font-mono text-xs text-neon-cyan font-bold select-none\">\n                [0{idx + 1}]\n              </div>\n              <p className=\"font-mono text-sm text-gray-300 leading-relaxed\">\n                {bullet}\n              </p>\n            </motion.div>\n          ))}\n        </div>\n\n        {/* Takeaway */}\n        <div className=\"bg-gradient-to-r from-neon-cyan/10 to-transparent p-4 rounded border border-neon-cyan/40 bg-noise relative\">\n          <div className=\"absolute -top-2.5 left-4 px-2 bg-black font-mono text-[10px] text-neon-cyan uppercase tracking-wider border border-neon-cyan/40\">\n            CRITICAL TAKEAWAY\n          </div>\n          <p className=\"font-mono text-sm text-neon-cyan font-semibold leading-relaxed\">\n            {digest.editorDigest.takeaway || \"Standing by...\"}\n          </p>\n        </div>\n      </div>\n\n      {/* Sequence Inspection Controls */}\n      <div className=\"border border-neon-magenta/40 p-4 rounded bg-black/60 bg-noise\">\n        <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4\">\n          <div>\n            <div className=\"flex items-center gap-1.5 font-mono text-xs text-neon-magenta font-semibold uppercase tracking-wider\">\n              <Layers className=\"w-4 h-4\" />\n              Multi-Agent Sequence Debugger\n            </div>\n            <p className=\"font-mono text-[11px] text-neon-magenta/60 mt-0.5\">\n              Inspect Agent 1 (Researcher) raw findings before Agent 2 (Editor) synthesized them.\n            </p>\n          </div>\n          <button\n            onClick={() => setShowRawResearcher(!showRawResearcher)}\n            className=\"cyber-button-magenta text-xs py-1.5 px-4 font-bold uppercase tracking-widest self-start sm:self-center shrink-0\"\n          >\n            {showRawResearcher ? \"HIDE PIPELINE RAW DATA\" : \"INSPECT AGENT_1 DATA\"}\n          </button>\n        </div>\n\n        {showRawResearcher && (\n          <motion.div\n            initial={{ opacity: 0, height: 0 }}\n            animate={{ opacity: 1, height: \"auto\" }}\n            className=\"mt-4 pt-4 border-t border-neon-magenta/20 space-y-4\"\n          >\n            <div className=\"flex items-center gap-1.5 text-xs text-neon-magenta font-bold uppercase tracking-widest\">\n              <Sparkles className=\"w-3.5 h-3.5 text-neon-magenta animate-pulse\" />\n              AGENT_1: PRIMARY RESEARCH NODES (FOUND 3-5 facts)\n            </div>\n\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n              {digest.researcherFindings.map((finding, index) => (\n                <div\n                  key={index}\n                  className=\"bg-neon-magenta/5 border border-neon-magenta/20 hover:border-neon-magenta/40 p-3.5 rounded font-mono text-xs space-y-2 transition-all relative overflow-hidden\"\n                >\n                  <div className=\"absolute top-2 right-2 text-[9px] text-neon-magenta/40\">\n                    FINDING 0{index + 1}\n                  </div>\n                  <div className=\"text-neon-magenta font-bold flex items-center gap-1\">\n                    <ExternalLink className=\"w-3 h-3\" />\n                    SOURCE: <span className=\"text-gray-200 font-semibold\">{finding.source}</span>\n                  </div>\n                  <div>\n                    <span className=\"text-neon-magenta/60 block mb-0.5 text-[10px] uppercase\">// EXTRACTED FACT:</span>\n                    <p className=\"text-gray-300 italic\">\"{finding.keyPoint}\"</p>\n                  </div>\n                  <div className=\"bg-black/60 p-2 rounded border border-neon-magenta/10 text-[11px]\">\n                    <span className=\"text-neon-magenta/50 block mb-0.5 text-[9px] uppercase\">// EXCERPT LOG:</span>\n                    <p className=\"text-neon-magenta/80 font-mono\">\"{finding.excerpt}\"</p>\n                  </div>\n                </div>\n              ))}\n            </div>\n          </motion.div>\n        )}\n      </div>\n    </motion.div>\n  );\n}\n"
    }
