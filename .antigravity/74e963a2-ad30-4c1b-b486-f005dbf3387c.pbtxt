  file_change {
    absolute_path_uri: "file:///src/components/Sidebar.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState } from \"react\";\nimport { SavedDigest } from \"../firebase\";\nimport { Database, Search, RefreshCw, Calendar, ChevronRight } from \"lucide-react\";\nimport { motion } from \"motion/react\";\n\ninterface SidebarProps {\n  history: SavedDigest[];\n  onSelectDigest: (digest: SavedDigest) => void;\n  selectedDigestId?: string;\n  onRefresh: () => void;\n  isLoading: boolean;\n}\n\nexport default function Sidebar({\n  history,\n  onSelectDigest,\n  selectedDigestId,\n  onRefresh,\n  isLoading,\n}: SidebarProps) {\n  const [searchTerm, setSearchTerm] = useState(\"\");\n\n  const filteredHistory = history.filter((item) =>\n    item.topic.toLowerCase().includes(searchTerm.toLowerCase())\n  );\n\n  const formatDate = (timestamp: number) => {\n    const d = new Date(timestamp);\n    const yr = d.getFullYear();\n    const mo = String(d.getMonth() + 1).padStart(2, \"0\");\n    const dy = String(d.getDate()).padStart(2, \"0\");\n    const hr = String(d.getHours()).padStart(2, \"0\");\n    const min = String(d.getMinutes()).padStart(2, \"0\");\n    return `${yr}-${mo}-${dy} [${hr}:${min}]`;\n  };\n\n  return (\n    <div className=\"flex flex-col h-full bg-dark-card/90 border border-neon-magenta/40 rounded p-4 shadow-[0_0_15px_rgba(255,0,127,0.1)] relative overflow-hidden bg-noise\">\n      {/* Sidebar Header */}\n      <div className=\"flex items-center justify-between border-b border-neon-magenta/20 pb-3 mb-4\">\n        <div className=\"flex items-center gap-2\">\n          <Database className=\"w-4 h-4 text-neon-magenta animate-pulse\" />\n          <span className=\"font-mono text-xs font-bold tracking-widest text-neon-magenta uppercase\">\n            COLD COGNITIVE STORAGE\n          </span>\n        </div>\n        <button\n          onClick={onRefresh}\n          disabled={isLoading}\n          className=\"p-1 hover:bg-neon-magenta/20 border border-neon-magenta/30 hover:border-neon-magenta rounded text-neon-magenta transition-colors disabled:opacity-40 cursor-pointer\"\n          title=\"SYNC ARCHIVE\"\n        >\n          <RefreshCw className={`w-3.5 h-3.5 ${isLoading ? \"animate-spin\" : \"\"}`} />\n        </button>\n      </div>\n\n      {/* Search Input */}\n      <div className=\"relative mb-4\">\n        <input\n          type=\"text\"\n          placeholder=\"QUERY MEMORY BANK...\"\n          value={searchTerm}\n          onChange={(e) => setSearchTerm(e.target.value)}\n          className=\"w-full bg-black/80 border border-neon-magenta/30 focus:border-neon-magenta text-neon-magenta font-mono text-xs py-2 pl-8 pr-3 outline-none transition-all placeholder:text-neon-magenta/40\"\n        />\n        <Search className=\"w-3.5 h-3.5 text-neon-magenta/60 absolute left-2.5 top-1/2 -translate-y-1/2\" />\n      </div>\n\n      {/* History List */}\n      <div className=\"flex-1 overflow-y-auto space-y-2 pr-1 min-h-[200px]\">\n        {filteredHistory.length === 0 ? (\n          <div className=\"flex flex-col items-center justify-center py-8 text-center border border-dashed border-neon-magenta/20 rounded\">\n            <span className=\"font-mono text-xs text-neon-magenta/50 uppercase\">\n              {searchTerm ? \"NO MATCHING CORES FOUND\" : \"COLD CORES UNPOPULATED\"}\n            </span>\n            <span className=\"font-mono text-[10px] text-neon-magenta/30 mt-1 uppercase\">\n              [EXECUTE SYNAPSE FLOW]\n            </span>\n          </div>\n        ) : (\n          filteredHistory.map((item) => {\n            const isSelected = item.id === selectedDigestId;\n            return (\n              <motion.button\n                key={item.id || item.timestamp}\n                whileHover={{ x: 2 }}\n                onClick={() => onSelectDigest(item)}\n                className={`w-full text-left p-3 rounded font-mono border transition-all relative overflow-hidden flex flex-col gap-1.5 ${\n                  isSelected\n                    ? \"bg-neon-magenta/15 border-neon-magenta shadow-[0_0_8px_rgba(255,0,127,0.25)]\"\n                    : \"bg-black/40 border-neon-magenta/20 hover:border-neon-magenta/50 hover:bg-neon-magenta/5\"\n                }`}\n              >\n                {/* Visual selected indicator tab */}\n                {isSelected && (\n                  <div className=\"absolute top-0 left-0 bottom-0 w-1 bg-neon-magenta\"></div>\n                )}\n\n                <div className=\"flex items-center justify-between\">\n                  <div className=\"flex items-center gap-1 font-mono text-[9px] text-neon-magenta/60 uppercase\">\n                    <Calendar className=\"w-2.5 h-2.5\" />\n                    {formatDate(item.timestamp)}\n                  </div>\n                  {isSelected && (\n                    <span className=\"text-[8px] px-1 bg-neon-magenta text-black font-extrabold uppercase scale-90\">\n                      ACTIVE\n                    </span>\n                  )}\n                </div>\n\n                <div className=\"font-semibold text-xs text-gray-200 line-clamp-2 uppercase leading-tight tracking-wide\">\n                  {item.topic}\n                </div>\n\n                <div className=\"flex items-center justify-between text-[10px] text-neon-magenta/70 mt-0.5 pt-1.5 border-t border-neon-magenta/10\">\n                  <span className=\"truncate max-w-[150px]\">\n                    Intro: {item.editorDigest.intro}\n                  </span>\n                  <ChevronRight className=\"w-3 h-3 text-neon-magenta/50 shrink-0\" />\n                </div>\n              </motion.button>\n            );\n          })\n        )}\n      </div>\n    </div>\n  );\n}\n"
    }
